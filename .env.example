# TailScan Configuration
# Copy this file to .env and fill in your values.

# ── Tailscale OAuth credentials ──
# Create at: https://login.tailscale.com/admin/settings/oauth
# Scopes needed: openid, profile, email, devices:read
# Redirect URI: http://<your-tailscale-ip>:8080/auth/callback

TS_CLIENT_ID=your_oauth_client_id
TS_CLIENT_SECRET=your_oauth_client_secret

# ── Your tailnet name ──
# Find at: https://login.tailscale.com/admin/machines (top of page)
# Use "-" to auto-detect the default tailnet for the OAuth client
TS_TAILNET=-

# ── Base URL ──
# Set to your Tailscale machine IP and port
# Example: http://100.64.0.1:8080
BASE_URL=http://100.64.0.1:8080

# ── Server binding ──
# Leave as 0.0.0.0 to bind all interfaces (Tailscale will filter access)
HOST=0.0.0.0
PORT=8080
