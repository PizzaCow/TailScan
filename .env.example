# Tailscale OAuth credentials
# Create at: https://login.tailscale.com/admin/settings/oauth
# Scopes needed: openid, profile, email
TAILSCALE_CLIENT_ID=your_client_id_here
TAILSCALE_CLIENT_SECRET=your_client_secret_here

# Redirect URI
TAILSCALE_REDIRECT_URI=http://100.97.92.103:8080/auth/callback

# Random secret key for session signing — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# Tailnet name (e.g. "example.com" or "user@gmail.com" — found in Tailscale admin)
TAILNET=your-tailnet-name
