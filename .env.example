# Password hash (sha256 of your chosen password)
# Generate with: python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
PASSWORD_HASH=your_sha256_hash_here

# Random secret key for session signing
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# Tailnet name (e.g. "example.com" or "user@gmail.com" — found in Tailscale admin)
TAILNET=your-tailnet-name
